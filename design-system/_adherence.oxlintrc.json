{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/data-display/**",
              "components/forms/**",
              "ui_kits/app/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:InterVariable))/i]",
        "message": "Font not provided by the design system. Available: InterVariable."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|graphColor|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, graphColor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|accent|success|warning|tag)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'accent' | 'success' | 'warning' | 'tag'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|type|leadingIcon|trailingIcon|onClick|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, type, leadingIcon, trailingIcon, onClick, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|white|text|ghost|space)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'white' | 'text' | 'ghost' | 'space'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevated|padding|onClick|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevated, padding, onClick, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|label|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, disabled, label, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|active|disabled|label|onClick|className|style|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, active, disabled, label, onClick, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|type|disabled|leadingIcon|onChange|className|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, defaultValue, placeholder, type, disabled, leadingIcon, onChange, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|selected|shortcut|onClick|className|style|children|key|ref|className|style|children)$/]",
        "message": "<MenuItem> doesn't accept that prop. Declared props: icon, selected, shortcut, onClick, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|shortcut|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: placeholder, shortcut, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShortcutKey'] > JSXAttribute > JSXIdentifier[name!=/^(?:shortcut|apple|ghost|style|key|ref|className|style|children)$/]",
        "message": "<ShortcutKey> doesn't accept that prop. Declared props: shortcut, apple, ghost, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, disabled, onChange, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
